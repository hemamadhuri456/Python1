class Solution:
    def numSquares(self, n: int) -> int:
        dp = [float("inf")] * (n + 1)

        dp[0] = 0  # base case

        for x in range(1, n + 1):
            j = 1
            while j * j <= x:
                dp[x] = min(dp[x], dp[x - j * j] + 1)
                j += 1

        return dp[n]
