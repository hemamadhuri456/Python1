class Solution:
    def reverseVowels(self, s: str) -> str:
        vowels = 'aeiouAEIOU'
        vowels_list = []
        count = 0
        for i in s:
            if i in vowels:
                vowels_list.append(i)
        vowels_list = vowels_list[::-1]
        s = list(s)
        for i in range(len(s)):
            if s[i] in vowels:
                s[i] = vowels_list[count]
                count += 1
        s = ''.join(s)
        return s
        
