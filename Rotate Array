class Solution:
    def rotate(self, nums, k):
        n = len(nums)
        k = k % n   # handle k > n
        
        # Step 1: Reverse whole array
        nums.reverse()
        
        # Step 2: Reverse first k elements
        nums[:k] = reversed(nums[:k])
        
        # Step 3: Reverse remaining elements
        nums[k:] = reversed(nums[k:])
