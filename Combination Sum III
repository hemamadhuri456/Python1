class Solution:
    def combinationSum3(self, k: int, n: int):
        result = []

        def backtrack(start, k, remaining, path):
            # If valid combination found
            if k == 0 and remaining == 0:
                result.append(path[:])
                return
            
            # Stop conditions
            if k < 0 or remaining < 0:
                return
            
            # Try numbers from 'start' to 9
            for num in range(start, 10):
                path.append(num)
                backtrack(num + 1, k - 1, remaining - num, path)
                path.pop()  # backtrack

        backtrack(1, k, n, [])
        return result
