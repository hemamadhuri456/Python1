import bisect
from typing import List


class Solution:
    def kthSmallest(self, matrix: List[List[int]], k: int) -> int:
        def check():
            cnt = 0
            for i in range(len(matrix)):
                cnt += bisect.bisect_right(matrix[i], mid)
                if cnt >= k: return True
            return False
        
        l = -10**9
        r = 10**9
        ans = 0
        while l <= r:
            mid = (l+r)//2
            if check():
                r = mid-1
                ans = mid
            else: l = mid+1
        return ans
