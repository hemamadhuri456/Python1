class Solution:
    def characterReplacement(self, s: str, k: int) -> int:

        l=0
        max_len = 0
        hash_mp = {}
        maxf=0
        for r in range(len(s)):
            hash_mp[s[r]] = hash_mp.get(s[r],0)+1
            maxf = max(maxf,hash_mp[s[r]])

            while(((r-l+1) - maxf)>k):
                hash_mp[s[l]]-=1
                l+=1

            max_len= max(max_len, r-l+1)

        return max_len

        
