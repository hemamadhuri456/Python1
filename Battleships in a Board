class Solution:
    def countBattleships(self, board: List[List[str]]) -> int:
        ships = 0
        for i in range(len(board)):
            for j in range(len(board[i])):
                if board[i][j] == 'X':
                    if j - 1 >= 0 and board[i][j - 1] == 'X':
                        continue
                    if i - 1 >= 0 and board[i - 1][j] == 'X':
                        continue
                    ships += 1
        return ships
