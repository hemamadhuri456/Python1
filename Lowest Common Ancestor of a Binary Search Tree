# Definition for a binary tree node.
# class TreeNode:
#     def __init__(self, x):
#         self.val = x
#         self.left = None
#         self.right = None

class Solution:
    def lowestCommonAncestor(self, root: 'TreeNode', p: 'TreeNode', q: 'TreeNode') -> 'TreeNode':
        
        contender = []
        
        queue = deque([root])
        while queue:
            curr = queue.popleft()
            if p.val <= curr.val <= q.val:
                contender.append(curr)
            if p.val >= curr.val >= q.val:
                contender.append(curr)
            if curr.left:
                queue.append(curr.left)
            if curr.right:
                queue.append(curr.right)
        return contender[0] if contender else root 
