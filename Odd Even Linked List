        if head==None or head.next==None:
            return head
        even_link=head.next
        ptr1=head
        ptr2=head
        while ptr1.next and ptr1.next.next:
            ptr2=ptr2.next
            ptr1.next=ptr1.next.next
            ptr2.next=ptr2.next.next
            ptr1=ptr1.next
        ptr1.next=even_link
        return head
