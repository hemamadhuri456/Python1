class Solution:
    def intersection(self, nums1: List[int], nums2: List[int]) -> List[int]:
        d = {}
        for n in nums1:
            if n not in d:
                d[n] = True
        output = []
        for n in nums2:
            if n in d and d[n]:
                d[n] = False
                output.append(n)
        return output
