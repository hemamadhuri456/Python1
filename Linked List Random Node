# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:

    def __init__(self, head: Optional[ListNode]):
        self.head = head
        self.length = 0
        curr = head
        while curr:
            self.length += 1
            curr = curr.next

    def getRandom(self) -> int:
        randNum = randint(0, self.length - 1)
        curr = self.head
        for i in range(randNum):
            curr = curr.next
        return curr.val
        


